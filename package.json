{
  "name": "boldpost",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "wp-scripts start admin/app/src/index.js --output-path=admin/app/build",
    "start:blockEditor": "wp-scripts start editor/app/src/index.js --output-path=editor/app/build",
    "build": "wp-scripts build admin/app/src/index.js --output-path=admin/app/build && npm run build:blockEditor && npm run build:postGrid && npm run build:postList && npm run build:postList2 && npm run build:postList3 && npm run build:postList4 && npm run build:postSlider && npm run build:postSlider2 && npm run build:postSlider3 && npm run build:postSlider4 && npm run build:categoryList && npm run build:postGrid2 && npm run build:postTicker && npm run build:postTicker2 && npm run build:heading && npm run build:button",
    "build:dashboard": "wp-scripts build admin/app/src/index.js --output-path=admin/app/build",
    "build:postList": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-list/src --output-path=public/blocks/post-list/build",
    "build:postList2": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-list-2/src --output-path=public/blocks/post-list-2/build",
    "build:postList3": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-list-3/src --output-path=public/blocks/post-list-3/build",
    "build:postList4": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-list-4/src --output-path=public/blocks/post-list-4/build",
    "build:postGrid": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-grid/src --output-path=public/blocks/post-grid/build",
    "build:postGrid2": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-grid-2/src --output-path=public/blocks/post-grid-2/build",
    "build:postGrid3": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-grid-3/src --output-path=public/blocks/post-grid-3/build",
    "build:postGrid4": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-grid-4/src --output-path=public/blocks/post-grid-4/build",
    "build:postSlider": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-slider/src --output-path=public/blocks/post-slider/build",
    "build:postSlider2": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-slider-2/src --output-path=public/blocks/post-slider-2/build",
    "build:postSlider3": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-slider-3/src --output-path=public/blocks/post-slider-3/build",
    "build:postSlider4": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-slider-4/src --output-path=public/blocks/post-slider-4/build",
    "build:categoryList": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/category-list/src --output-path=public/blocks/category-list/build",
    "build:postTicker": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-ticker/src --output-path=public/blocks/post-ticker/build",
    "build:postTicker2": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/post-ticker-2/src --output-path=public/blocks/post-ticker-2/build",
    "build:blockEditor": "wp-scripts build --blocks-manifest --webpack-src-dir=editor/app/src --output-path=editor/app/build",
    "build:heading": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/heading/src --output-path=public/blocks/heading/build",
    "build:button": "wp-scripts build --blocks-manifest --webpack-src-dir=public/blocks/button/src --output-path=public/blocks/button/build"
  },
  "devDependencies": {
    "@wordpress/scripts": "^31.2.0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.1.4",
    "bootstrap": "^5.3.8"
  }
}